<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financeiro Mensal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { height: 100vh; background-color: #f8fafc; font-family: sans-serif; }
        .money-input { text-align: right; }
        
        /* Ajustes para Impressão */
        @media print {
            .no-print { display: none !important; }
            body { background: white; overflow: visible; }
            .print-area { grid-column: span 12 / span 12 !important; }
            .card-container { border: 1px solid #eee !important; box-shadow: none !important; }
        }

        /* Estilo do Check */
        .item-pago { opacity: 0.5; text-decoration: line-through; }
    </style>
</head>
<body class="p-4 overflow-hidden">

    <div class="max-w-[1400px] mx-auto h-full flex flex-col gap-4">
        
        <div class="grid grid-cols-4 gap-4 h-24">
            <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm flex flex-col justify-center">
                <span class="text-xs text-gray-400 uppercase font-bold tracking-wider">A Receber</span>
                <span id="totalReceber" class="text-2xl font-black text-green-600">R$ 0,00</span>
            </div>
            <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm flex flex-col justify-center">
                <span class="text-xs text-gray-400 uppercase font-bold tracking-wider">A Pagar</span>
                <span id="totalPagar" class="text-2xl font-black text-red-600">R$ 0,00</span>
            </div>
            <div class="bg-blue-600 p-4 rounded-xl shadow-md flex flex-col justify-center">
                <span class="text-xs text-blue-100 uppercase font-bold tracking-wider">Saldo Final</span>
                <span id="saldoGeral" class="text-2xl font-black text-white">R$ 0,00</span>
            </div>
            <div class="no-print flex flex-col gap-2 justify-center">
                <button onclick="window.print()" class="bg-gray-800 text-white font-bold py-2 px-4 rounded-lg text-xs uppercase hover:bg-black transition-all">🖨️ Imprimir PDF</button>
                <button onclick="limparMes()" class="bg-white border border-red-200 text-red-500 font-bold py-2 px-4 rounded-lg text-xs uppercase hover:bg-red-50 transition-all">🗑️ Limpar Mês</button>
            </div>
        </div>

        <div class="flex-1 grid grid-cols-12 gap-4 overflow-hidden">
            
            <div class="col-span-3 bg-white p-6 rounded-xl border border-gray-200 shadow-sm no-print">
                <h2 class="font-bold text-gray-700 mb-6 border-b pb-2 text-sm uppercase tracking-widest">Lançamento</h2>
                <div class="space-y-5">
                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 mb-1 uppercase">Descrição</label>
                        <input type="text" id="desc" class="w-full border-b-2 border-gray-100 p-2 focus:border-blue-500 outline-none text-sm transition-all font-medium">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 mb-1 uppercase">Valor</label>
                        <input type="text" id="valor" oninput="mascaraMoeda(this)" placeholder="R$ 0,00" class="money-input w-full border-b-2 border-gray-100 p-2 focus:border-blue-500 outline-none font-mono font-bold text-blue-700 text-lg">
                    </div>
                    <div class="flex gap-2 pt-4">
                        <button onclick="adicionar('receber')" class="flex-1 bg-green-500 hover:bg-green-600 text-white font-black py-3 rounded-lg text-xs uppercase shadow-lg shadow-green-100">Receber</button>
                        <button onclick="adicionar('pagar')" class="flex-1 bg-red-500 hover:bg-red-600 text-white font-black py-3 rounded-lg text-xs uppercase shadow-lg shadow-red-100">Pagar</button>
                    </div>
                </div>
            </div>

            <div class="print-area col-span-9 grid grid-cols-2 gap-4 overflow-hidden h-full">
                
                <div class="card-container bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col overflow-hidden">
                    <div class="p-4 bg-green-50 border-b border-green-100 font-black text-green-700 text-xs uppercase flex justify-between">
                        <span>Entradas</span>
                        <span id="subReceber" class="text-[10px] opacity-70"></span>
                    </div>
                    <div id="listaReceber" class="flex-1 overflow-y-auto p-4 space-y-3"></div>
                </div>

                <div class="card-container bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col overflow-hidden">
                    <div class="p-4 bg-red-50 border-b border-red-100 font-black text-red-700 text-xs uppercase flex justify-between">
                        <span>Saídas</span>
                        <span id="subPagar" class="text-[10px] opacity-70"></span>
                    </div>
                    <div id="listaPagar" class="flex-1 overflow-y-auto p-4 space-y-3"></div>
                </div>

            </div>
        </div>
    </div>

    <script>
        let db = JSON.parse(localStorage.getItem('financas_v2')) || { pagar: [], receber: [] };

        function mascaraMoeda(i) {
            let v = i.value.replace(/\D/g,'');
            v = (v/100).toFixed(2) + '';
            v = v.replace(".", ",");
            v = v.replace(/(\d)(\d{3})(\d{3}),/g, "$1.$2.$3,");
            v = v.replace(/(\d)(\d{3}),/g, "$1.$2,");
            i.value = 'R$ ' + v;
        }

        function formatarParaReal(valor) {
            return valor.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'});
        }

        function adicionar(tipo) {
            const desc = document.getElementById('desc').value;
            const valorRaw = document.getElementById('valor').value.replace(/[R$\s.]/g, '').replace(',', '.');
            const valor = parseFloat(valorRaw);

            if(!desc || isNaN(valor)) return;

            db[tipo].push({ id: Date.now(), desc, valor, status: 'pendente' });
            salvar();
            document.getElementById('desc').value = '';
            document.getElementById('valor').value = '';
        }

        function toggleStatus(tipo, id) {
            const item = db[tipo].find(i => i.id === id);
            item.status = item.status === 'pago' ? 'pendente' : 'pago';
            salvar();
        }

        function remover(tipo, id) {
            if(confirm("Excluir este item?")) {
                db[tipo] = db[tipo].filter(item => item.id !== id);
                salvar();
            }
        }

        function limparMes() {
            if(confirm("Isso apagará TODOS os dados para iniciar um novo mês. Confirma?")) {
                db = { pagar: [], receber: [] };
                salvar();
            }
        }

        function salvar() {
            localStorage.setItem('financas_v2', JSON.stringify(db));
            renderizar();
        }

        function renderizar() {
            const lPagar = document.getElementById('listaPagar');
            const lReceber = document.getElementById('listaReceber');
            lPagar.innerHTML = lReceber.innerHTML = '';

            let totalP = 0, totalR = 0;

            const criarItem = (item, tipo) => {
                const isPago = item.status === 'pago';
                const cor = tipo === 'receber' ? 'green' : 'red';
                return `
                    <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg border-l-4 border-${cor}-500 ${isPago ? 'item-pago' : ''}">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" ${isPago ? 'checked' : ''} onclick="toggleStatus('${tipo}', ${item.id})" class="no-print w-4 h-4 cursor-pointer">
                            <span class="font-semibold text-gray-700">${item.desc}</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="font-bold text-${cor}-600 font-mono">${formatarParaReal(item.valor)}</span>
                            <button onclick="remover('${tipo}', ${item.id})" class="no-print text-gray-300 hover:text-red-500 text-xs">✕</button>
                        </div>
                    </div>`;
            };

            db.pagar.forEach(item => { totalP += item.valor; lPagar.innerHTML += criarItem(item, 'pagar'); });
            db.receber.forEach(item => { totalR += item.valor; lReceber.innerHTML += criarItem(item, 'receber'); });

            document.getElementById('totalPagar').innerText = formatarParaReal(totalP);
            document.getElementById('totalReceber').innerText = formatarParaReal(totalR);
            document.getElementById('saldoGeral').innerText = formatarParaReal(totalR - totalP);
        }

        renderizar();
    </script>
</body>
</html>
